# ============================================================================
# DPM Diving — Claude Integration Server
# Copy this file to .env (server) or apps/server/.env and fill in real values.
# Never commit .env files. All values must come from the corresponding
# providers' guest accounts that Miguel will provision after NDA signing.
# ============================================================================

# --- Runtime ---
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# --- Anthropic (Claude API) ---
# Get from: https://console.anthropic.com/settings/keys
# Required scope: messages.create + tool_use
# Account must be Tier 2+ for production traffic (1000 RPM)
ANTHROPIC_API_KEY=sk-ant-api03-REPLACE_ME
ANTHROPIC_MODEL_PRIMARY=claude-sonnet-4-6
ANTHROPIC_MODEL_FALLBACK=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_JUDGE=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# --- Supabase (PostgreSQL + Auth + Storage) ---
# Project URL + service-role key (server-side only, never expose to client)
SUPABASE_URL=https://REPLACE_ME.supabase.co
SUPABASE_SERVICE_ROLE_KEY=REPLACE_ME
SUPABASE_ANON_KEY=REPLACE_ME

# Direct Postgres connection (Drizzle migrations + queries)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:REPLACE_ME@db.REPLACE_ME.supabase.co:5432/postgres

# --- Respond.io ---
# Webhook secret used to verify incoming HMAC signatures
RESPOND_IO_WEBHOOK_SECRET=REPLACE_ME
# API key (scoped: send_message + read_conversation_history only)
RESPOND_IO_API_KEY=REPLACE_ME
RESPOND_IO_API_BASE_URL=https://api.respond.io/v2
# Meta WhatsApp Business catalog id for send_product_card tool (required).
META_CATALOG_ID=REPLACE_ME

# --- Google Apps Script (roster lookup) ---
# Per-sede URLs are stored in the sedes table; this is a hard timeout fallback
APPS_SCRIPT_TIMEOUT_MS=2000

# --- Observability ---
SENTRY_DSN=
AXIOM_TOKEN=
AXIOM_DATASET=dpm-server-prod

# --- Cost guards ---
# Hard daily spending cap in USD (process refuses Anthropic calls above this)
ANTHROPIC_DAILY_SPEND_LIMIT_USD=100
# Notification thresholds as fractions of monthly budget
COST_ALERT_THRESHOLDS=0.5,0.75,1.0
